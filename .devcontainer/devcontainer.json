{
  "name": "QEMU Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.remote-explorer"
      ]
    }
  },
  "forwardPorts": [5900],
  "portsAttributes": {
    "5900": {
      "label": "VNC",
      "onAutoForward": "notify"
    }
  }
}
